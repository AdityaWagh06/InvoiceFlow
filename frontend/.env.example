# Clerk publishable key (frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk secret key (server only)
CLERK_SECRET_KEY=

# Clerk sign-in URL path
CLERK_SIGN_IN_URL=/sign-in
# Clerk sign-up URL path
CLERK_SIGN_UP_URL=/sign-up
# Redirect after sign-in
CLERK_AFTER_SIGN_IN_URL=/dashboard
# Redirect after sign-up
CLERK_AFTER_SIGN_UP_URL=/dashboard

# Public base URL for the frontend app
NEXT_PUBLIC_APP_URL=

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=

# Sentry DSN for frontend error reporting
NEXT_PUBLIC_SENTRY_DSN=

# PostHog project key
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog instance URL
NEXT_PUBLIC_POSTHOG_HOST=
